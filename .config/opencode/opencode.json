{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "nebula-kimi": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Nebula (Kimi via Nebula proxy)",
      "options": {
        "baseURL": "http://localhost:8080/v1",
        "apiKey": "set-in-nebula-env",
        "headers": {
          "x-nebula-provider": "kimi",
          "x-nebula-session": "opencode-kimi",
          "x-nebula-user": "Leonard"
        }
      },
      "models": {
        "kimi-k2.6": {
          "name": "Kimi K2.6 via Nebula",
          "limit": { "context": 256000, "output": 32000 }
        },
        "kimi-k2.5": {
          "name": "Kimi K2.5 via Nebula",
          "limit": { "context": 256000, "output": 32000 }
        },
        "moonshot-v1-128k": {
          "name": "Moonshot V1 128k via Nebula",
          "limit": { "context": 131072, "output": 8192 }
        },
        "moonshot-v1-auto": {
          "name": "Moonshot V1 Auto via Nebula",
          "limit": { "context": 131072, "output": 8192 }
        }
      }
    },
    "box": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "box",
      "options": {
        "baseURL": "https://llm.box.home.arpa",
        "apiKey": "{env:BOX_API_KEY}"
      },
      "models": {
        "Qwen3-Coder-Next-Q6_K": {
          "name": "Qwen3-Coder-Next"
        },
        "GLM-4.7-Flash-Q6_K_XL": {
          "name": "GLM-4.7-Flash"
        },
        "gpt-oss-120b-Q8_0": {
          "name": "gpt-oss-120b"
        },
        "Qwen3.5-122B-A10B-Q4_0": {
          "name": "Qwen3.5-122B-A10B-Q4_0"
        },
        "Qwen3.5-27B-Q8_0": {
          "name": "Qwen3.5-27B-Q8_0"
        },
        "gpt-oss-20b-Q8_0": {
          "name": "gpt-oss-20b-Q8_0"
        }
      }
    }
  },
  "default_agent": "plan",
  "autoupdate": true,
  "permission": {
    "edit": "ask",
    "bash": {
      "*": "ask",
      "pwd": "allow",
      "git status": "allow",
      "grep *": "allow",
      "rg *": "allow",
      "find *": "allow",
      "tree *": "allow",
      "sed *": "allow",
      "mkdir *": "allow",
      "mkdir -p*": "allow",
      "ls *": "allow",
      "wc *": "allow",
      "gh issue view:*": "allow",
      "gh pr view:*": "allow",
      "gh pr diff:*": "allow",
      "go test:*": "allow",
      "go vet:*": "allow",
      "deadcode:*": "allow",
      "gofmt:*": "allow",
      "curl *": "ask",
      "rm *": "ask",
      "sed -i*": "ask",
      "sed * -i *": "ask",
      "sed * -i' *": "ask",
      "sed --in-place*": "ask",
      "sed * --in-place *": "ask"
    }
  },
  "agent": {
    "build": {
      "mode": "primary",
      "permission": {
        "edit": "ask",
        "bash": "ask"
      }
    },
    "plan": {
      "mode": "primary",
      "permission": {
        "edit": "deny",
        "bash": {
          "mkdir *": "ask",
          "mkdir -p*": "ask"
        }
      }
    },
    "review": {
      "mode": "subagent",
      "description": "Reviews code for best practices and potential issues",
      "permission": {
        "edit": "deny",
        "bash": {
          "mkdir *": "ask",
          "mkdir -p*": "ask"
        }
      }
    },
    "apply": {
      "mode": "primary",
      "permission": {
        "edit": "allow"
      }
    }
  },
  "command": {
    "review-staged": {
      "template": "Review the current staged changes and find issues/code that was not updated correctly and suggest improvements",
      "description": "Review staged changes for issues",
      "agent": "review"
    },
    "review-pr": {
      "template": "Review the current branch changes against main and find issues/code that was not updated correctly and suggest improvements",
      "description": "Review branch changes against main for issues",
      "agent": "review"
    },
    "commit": {
      "template": "Create a git commit using conventional commits format: type(scope): description\n\nTypes: feat, fix, docs, style, refactor, perf, test, build, ci, chore, revert\n\nGuidelines:\n- Create ONLY a subject line. NO body. NO coauthors.\n- Subject line only (50 chars or less)\n- Focus on the WHY or overall purpose, not WHAT changed\n\nCurrent context:\n- Git status: `git status`\n- Git diff: `git diff HEAD`\n- Current branch: `git branch --show-current`\n- Recent commits: `git log --oneline -10`",
      "description": "Create a git commit with conventional commit message",
      "agent": "build"
    }
  },
  "mcp": {
    "web": {
      "type": "local",
      "enabled": true,
      "command": ["/Users/leo/dev/mcp/web-mcp/web-mcp"]
    },
    "nvim-lsp": {
      "type": "local",
      "enabled": true,
      "command": ["/Users/leo/dev/mcp/nvim-lsp-mcp/nvim-lsp-mcp"]
    }
  },
  "lsp": {
    "typescript": { "disabled": true },
    "eslint": { "disabled": true },
    "gopls": { "disabled": true },
    "ruby-lsp": { "disabled": true },
    "pyright": { "disabled": true },
    "elixir-ls": { "disabled": true },
    "zls": { "disabled": true },
    "csharp": { "disabled": true },
    "vue": { "disabled": true },
    "rust": { "disabled": true },
    "clangd": { "disabled": true },
    "svelte": { "disabled": true }
  }
}
