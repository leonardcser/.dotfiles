{
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "0",
    "CLAUDE_CODE_AUTO_COMPACT_WINDOW": "400000",
    "CLAUDE_CODE_NO_FLICKER": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "mcp__nvim-lsp__read-lints",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(echo *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(find *)",
      "Bash(tree *)",
      "Bash(sed *)",
      "Bash(mkdir *)",
      "Bash(mkdir -p*)",
      "Bash(ls *)",
      "Bash(wc *)",
      "Bash(gh issue view:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr diff:*)",
      "Bash(go test:*)",
      "Bash(go vet:*)",
      "Bash(deadcode:*)",
      "Bash(gofmt:*)",
      "WebFetch",
      "WebSearch",
      "mcp__intermcp__list_agents",
      "mcp__intermcp__send",
      "Bash(curl *)",
      "Bash(cargo check:*)",
      "WebFetch(domain:llm.box.home.arpa)",
      "WebFetch(domain:links.duckduckgo.com)",
      "Bash(cargo build:*)",
      "Bash(cargo test:*)",
      "Bash(cargo fmt:*)",
      "Bash(cargo clippy:*)",
      "Bash(cargo run:*)",
      "Bash(tmux send-keys:*)"
    ],
    "deny": [
      "Read(./.env)"
    ],
    "ask": [],
    "defaultMode": "default"
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true
  },
  "sandbox": {
    "enabled": true,
    "network": {
      "allowedDomains": [
        "*"
      ]
    }
  },
  "effortLevel": "high",
  "autoMemoryEnabled": false,
  "showThinkingSummaries": true,
  "skipDangerousModePermissionPrompt": true,
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": false
}
