{
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "0",
    "CLAUDE_CODE_AUTO_COMPACT_WINDOW": "400000",
    "CLAUDE_CODE_NO_FLICKER": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "mcp__nvim-lsp__read-lints",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(echo *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(find *)",
      "Bash(tree *)",
      "Bash(sed *)",
      "Bash(mkdir *)",
      "Bash(mkdir -p*)",
      "Bash(ls *)",
      "Bash(wc *)",
      "Bash(gh issue view:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr diff:*)",
      "Bash(go test:*)",
      "Bash(go vet:*)",
      "Bash(deadcode:*)",
      "Bash(gofmt:*)",
      "WebFetch",
      "WebSearch",
      "mcp__intermcp__list_agents",
      "mcp__intermcp__send",
      "Bash(curl *)"
    ],
    "deny": ["Read(./.env)"],
    "ask": [
      "Bash(rm *)",
      "Bash(sed -i*)",
      "Bash(sed * -i *)",
      "Bash(sed * -i'*)",
      "Bash(sed --in-place*)",
      "Bash(sed * --in-place *)"
    ]
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true
  },
  "sandbox": {
    "enabled": true,
    "network": {
      "allowedDomains": ["*"]
    }
  },
  "effortLevel": "medium",
  "voiceEnabled": false,
  "autoMemoryEnabled": false,
  "showThinkingSummaries": true,
  "skipDangerousModePermissionPrompt": true
}
