#!/usr/bin/env bash

# Frecency tracker — logs directory visits and sorts paths by frequency + recency.
# Usage:
#   frecency log [--context=NAME] <path>   Log a visit (appends timestamp, prunes old entries)
#   frecency top [--context=NAME]          Output known paths sorted by frecency (highest first)

set -euo pipefail

FRECENCY_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/frecency"
CONTEXT="default"
PRUNE_DAYS=90

history_file() {
    echo "${FRECENCY_DIR}/${CONTEXT}.history"
}

ensure_history() {
    local f
    f=$(history_file)
    [[ -f "$f" ]] || { mkdir -p "$(dirname "$f")" && touch "$f"; }
}

cmd_log() {
    local path="$1" f
    ensure_history
    f=$(history_file)
    local now cutoff
    now=$(date +%s)
    cutoff=$((now - PRUNE_DAYS * 86400))

    echo -e "${now}\t${path}" >> "$f"
    awk -F'\t' -v cutoff="$cutoff" '$1 >= cutoff' "$f" > "${f}.tmp" \
        && mv "${f}.tmp" "$f"
}


cmd_top() {
    ensure_history
    local f
    f=$(history_file)
    awk -F'\t' -v now="$(date +%s)" -v home="$HOME" '
    function normalize(p) {
        if (substr(p, 1, length(home)) == home)
            return "~" substr(p, length(home) + 1)
        return p
    }
    {
        path = normalize($2)
        age = (now - $1) / 3600
        if (age < 1)        score[path] += 16
        else if (age < 24)  score[path] += 8
        else if (age < 168) score[path] += 4
        else if (age < 720) score[path] += 2
        else                score[path] += 1
    }
    END {
        for (p in score) print score[p] "\t" p
    }
    ' "$f" | sort -t'	' -k1,1rn | cut -f2 | while IFS= read -r p; do
        # Filter out non-existent directories
        local expanded="${p/#\~/$HOME}"
        [[ -d "$expanded" ]] && echo "$p"
    done
}

cmd="${1:-}"; shift || true
while [[ "${1:-}" == --context=* ]]; do
    CONTEXT="${1#--context=}"; shift
done

case "$cmd" in
    log)
        [[ -n "${1:-}" ]] || { echo "Usage: frecency log [--context=NAME] <path>" >&2; exit 1; }
        cmd_log "$1"
        ;;
    top)
        cmd_top
        ;;
    *)
        echo "Usage: frecency {log|top} [--context=NAME] [args]" >&2
        exit 1
        ;;
esac
